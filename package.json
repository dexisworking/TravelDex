{
  "name": "traveldex-backend",
  "version": "1.0.0",
  "description": "Secure backend proxy for TravelDex API keys",
  "main": "server.js",
  "scripts": {
    "build": "npm run build:css",
    "build:css": "tailwindcss -i ./tailwind.input.css -o ./public/tailwind.generated.css --minify",
    "check": "node --check server.js",
    "dev": "node server.js",
    "prestart": "npm run build:css",
    "start": "node server.js"
  },
  "dependencies": {
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "node-fetch": "^2.7.0"
  },
  "devDependencies": {
    "tailwindcss": "^3.4.17"
  }
}
