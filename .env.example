# Server
PORT=3000

# Gemini
GEMINI_MODEL=gemini-2.5-flash
GEMINI_API_KEY=YOUR_GEMINI_API_KEY_HERE

# Google Maps
# GOOGLE_MAPS_API_KEY is sent to the browser to load the Maps JavaScript API.
GOOGLE_MAPS_API_KEY=YOUR_GOOGLE_MAPS_BROWSER_API_KEY_HERE

# Optional: use a separate server-side key for Geocoding, Places, and Routes.
# If omitted, the server will fall back to GOOGLE_MAPS_API_KEY.
GOOGLE_MAPS_SERVER_API_KEY=YOUR_GOOGLE_MAPS_SERVER_API_KEY_HERE

# Optional: set a custom Map ID for Advanced Markers. Defaults to DEMO_MAP_ID.
GOOGLE_MAPS_MAP_ID=YOUR_GOOGLE_MAPS_MAP_ID
